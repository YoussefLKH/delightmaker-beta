# ═══════════════════════════════════════════════════
# DELIGHTMAKER — ENVIRONMENT VARIABLES TEMPLATE
# ═══════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value below with your real keys
#   3. NEVER commit your .env file — it's in .gitignore
#
# ═══════════════════════════════════════════════════


# ── APP SETTINGS ──────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000


# ── FIREBASE (Client Side) ────────────────────────
# Firebase Console → Project Settings → Your Apps → Web App → Config

FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here


# ── FIREBASE ADMIN (Server Side) ──────────────────
# Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key → copy values from the downloaded JSON

FIREBASE_ADMIN_PROJECT_ID=your_project_id_here
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"


# ── STRIPE ────────────────────────────────────────
# stripe.com → Developers → API Keys
# Use TEST keys (pk_test_ / sk_test_) during development

STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# stripe.com → Developers → Webhooks → Add Endpoint → Reveal Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id_here
STRIPE_PRICE_BUSINESS=price_your_business_price_id_here


# ── CLAUDE API (Anthropic) ────────────────────────
# console.anthropic.com → API Keys

ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022


# ── RESEND (Email) ────────────────────────────────
# resend.com → API Keys → Create API Key
# Make sure your domain (e.g. delightmaker.ca) is verified in Resend

RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=hello@yourdomain.ca
RESEND_FROM_NAME=Delightmaker
EMAIL_FROM=hello@yourdomain.ca

# Purpose-specific FROM addresses — all must be on your verified domain
EMAIL_ORDERS=orders@yourdomain.ca
EMAIL_SUPPORT=support@yourdomain.ca
EMAIL_BILLING=billing@yourdomain.ca
EMAIL_COLTON=your_name@yourdomain.ca


# ── JWT SECRET ────────────────────────────────────
# Used for signing approval tokens in emails
# Generate a strong random string at: randomkeygen.com (use "256-bit WEP Keys")

JWT_SECRET=your_long_random_secret_here
JWT_EXPIRY=7d


# ── ADMIN DETAILS ─────────────────────────────────
ADMIN_EMAIL=your_admin_email@yourdomain.ca
ADMIN_NAME=YourName


# ── GOOGLE MAPS ───────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
# IMPORTANT: Restrict this key by HTTP referrer in Google Cloud Console

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ── VERCEL CRON PROTECTION ────────────────────────
# Protects /api/cron/* endpoints from unauthorized triggering
# Generate a strong random string at: randomkeygen.com
# Add this same value in Vercel → Settings → Environment Variables

CRON_SECRET=your_long_random_cron_secret_here


# ── RATE LIMITING ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
